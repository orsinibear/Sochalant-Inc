# Wallet & RPC
# Get a project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Unichain Sepolia RPC (defaults to https://sepolia.unichain.org)
NEXT_PUBLIC_UNICHAIN_SEPOLIA_RPC_URL=https://sepolia.unichain.org

# Deployed contracts — defaults in lib/contracts.ts match contract/frontend.md
# Override here if addresses change after redeployment
NEXT_PUBLIC_SOCHALANT_HOOK_ADDRESS=
NEXT_PUBLIC_HEDGE_CALLBACK_ADDRESS=
NEXT_PUBLIC_TOKEN_A_ADDRESS=
NEXT_PUBLIC_TOKEN_B_ADDRESS=
NEXT_PUBLIC_POOL_MANAGER_ADDRESS=

# Pool configuration (must match your deployed pool)
NEXT_PUBLIC_POOL_FEE=3000
NEXT_PUBLIC_POOL_TICK_SPACING=60

# Reactive Lasna (optional — for monitoring ReactiveOracleSync)
NEXT_PUBLIC_REACTIVE_ORACLE_ADDRESS=
NEXT_PUBLIC_REACTIVE_LASNA_RPC_URL=https://lasna-omni-rpc.rnk.dev
